# .env.local — Claude Code environment for free local Qwen inference
# Source this file before launching Claude Code:
#   source .env.local && claude

# Point Claude Code at the local LiteLLM proxy instead of Anthropic's servers
ANTHROPIC_BASE_URL=http://localhost:4000
ANTHROPIC_API_KEY=sk-local-free

# Override the model to match an alias defined in litellm_config.yaml
# (Claude Code sends this model name in requests)
CLAUDE_CODE_MODEL=claude-3-5-sonnet-20241022

# Optional: disable telemetry
CLAUDE_CODE_DISABLE_TELEMETRY=1
